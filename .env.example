# Database
DATABASE_URL=./data/ai-dev-pro.db

# LLM Providers
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
GOOGLE_API_KEY=

# Telegram
TG_GROUP_CHAT_ID=

# Proxy (leave empty if not needed)
HTTPS_PROXY=

# Server
API_PORT=3000

# Agent filesystem workspace when an agent has no per-agent work_dir set (supports {agentId})
# AGENT_WORK_DIR_TEMPLATE=/data/agent-pro/{agentId}

# Runtime logs (NDJSON in file; Web UI: 运行日志)
# LOG_DIR=./logs
# LOG_FILE=./logs/app.log
# LOG_MAX_LINES=10000

# Figma MCP Integration
# Option 1 (recommended): stdio via figma-developer-mcp + Personal Access Token
# FIGMA_MCP_COMMAND=npx
# FIGMA_MCP_ARGS=-y figma-developer-mcp --stdio
# FIGMA_ACCESS_TOKEN=figd_xxx       → Figma Settings > Security > Personal access tokens
#
# Option 2: Remote official server (requires OAuth browser login, not for headless)
# FIGMA_MCP_URL=https://mcp.figma.com/mcp
#
# Option 3: Local Figma desktop app (requires desktop app open with MCP enabled)
# FIGMA_MCP_URL=http://127.0.0.1:3845/mcp

# Lark / 飞书 Integration
# LARK_APP_ID=cli_xxxxxxxxxxxxx
# LARK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# LARK_BASE_URL=https://open.feishu.cn/open-apis   → 国际版用 https://open.larksuite.com/open-apis

# System Skills (managed via WebUI /env-vars, listed here for reference)
# GITHUB_TOKEN=       → Git skills (GitHub)
# GITLAB_TOKEN=       → Git skills (GitLab)
# JENKINS_TOKEN=      → Jenkins skills (user:token format)
