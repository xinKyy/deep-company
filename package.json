{
  "name": "ai-dev-pro",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @ai-dev-pro/core build && pnpm --filter @ai-dev-pro/telegram build && pnpm --filter @ai-dev-pro/api dev",
    "dev:all": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "db:generate": "pnpm --filter @ai-dev-pro/core db:generate",
    "db:migrate": "pnpm --filter @ai-dev-pro/core db:migrate"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ],
    "ignoredBuiltDependencies": [
      "puppeteer"
    ]
  }
}
